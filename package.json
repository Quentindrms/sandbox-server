{
  "name": "sandbox-server",
  "version": "1.0.0",
  "description": "NodeJS sandbox",
  "main": "index.js",
  "scripts": {
    "dev": "tsx --watch src/main.ts & pnpm run watch:css",
    "format": "biome format .",
    "format:write": "biome format . --write",
    "build:css": "tailwindcss -i ./style.css -o ./public/style.css",
    "watch:css": "tailwindcss -i ./style.css -o ./public/style.css --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/cli": "^4.3.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
